{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Rodar Python Limpo",
            "type": "shell",
            // Aqui ele usa o python do seu ambiente virtual local
            "command": ".venv/Scripts/python.exe '${file}'",
            "presentation": {
                "echo": false, // Esconde o comando gigante
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true // Limpa o terminal antes de rodar
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}